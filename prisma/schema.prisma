generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum SessionType {
  PRACTICE
  REVIEW
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum MessageRole {
  CLIENT
  THERAPIST
  SYSTEM
}

enum ScenarioContextType {
  MEDICAL_FAMILY_THERAPY
  DOCTOR_HANDOFF
  PEDIATRIC_PARENT_CHILD
  INDIVIDUAL
  COUPLES
  FAMILY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  entraObjectId String?   @unique
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  sessions      Session[]
}

model Scenario {
  id                String    @id @default(cuid())
  title             String    @unique
  contextType       ScenarioContextType @default(INDIVIDUAL)
  dsmCategory       String
  presentingProblem String
  systemPrompt      String
  caseWriteup       Json?
  objectives        String[]
  difficulty        String
  ageGroup          String    @default("adult")
  acuityLevel       String    @default("moderate")
  referralSource    String?
  sessionParticipants String[]
  generationSettings Json?
  isTemplate        Boolean   @default(false)
  sessions          Session[]

  @@index([contextType])
  @@index([difficulty])
}

model Session {
  id              String        @id @default(cuid())
  userId          String
  scenarioId      String
  type            SessionType   @default(PRACTICE)
  status          SessionStatus @default(ACTIVE)
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  practiceSeconds Int           @default(0)
  reviewSeconds   Int           @default(0)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario        Scenario      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  messages        Message[]
  review          SessionReview?

  @@index([userId])
  @@index([scenarioId])
}

model Message {
  id            String      @id @default(cuid())
  sessionId     String
  role          MessageRole
  content       String
  audioBlobPath String?
  sequence      Int
  createdAt     DateTime    @default(now())
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model SessionReview {
  id                         String  @id @default(cuid())
  sessionId                  String  @unique
  aiDebrief                  String?
  objectiveScores            Json?
  instructorNotes            String?
  learnerConclusions         String?
  learnerWhatILearned        String?
  learnerInterventionRationale String?
  session                    Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
