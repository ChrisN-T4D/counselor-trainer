# Copy to .env and fill in values

# Railway Postgres (or local Postgres for development)
DATABASE_URL=postgresql://user:password@host:5432/counselor_trainer

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Production (Railway): set to your public app URL, e.g. https://your-app.up.railway.app
# Do NOT use localhost on Railway — it causes login redirects to localhost.
# AUTH_URL=https://your-app.up.railway.app

# Local dev only
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama or other OpenAI-compatible LLM endpoint
OPENAI_BASE_URL=https://your-ollama-host.example.com/v1
OPENAI_API_KEY=unused
OPENAI_MODEL=llama3.1

# Voice providers (Phase 0/1: noop; Phase 2: elevenlabs)
TTS_PROVIDER=noop
STT_PROVIDER=noop

# ElevenLabs (Phase 2)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
