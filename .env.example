# Copy to .env and fill in values

# Railway Postgres (or local Postgres for development)
DATABASE_URL=postgresql://user:password@host:5432/counselor_trainer

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Production (Railway): optional — your REAL public domain only (do not copy this comment line).
# Example: AUTH_URL=https://counselor-trainer-production.up.railway.app
# Wrong/placeholder values will crash the app. Leave unset if unsure; trustHost handles Railway.

# Local dev only
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama or other OpenAI-compatible LLM endpoint
OPENAI_BASE_URL=https://your-ollama-host.example.com/v1
OPENAI_API_KEY=unused
OPENAI_MODEL=llama3.1
# Chat replies (in-session client turns) — separate from long-form generation
OPENAI_CHAT_MAX_TOKENS=2048
# Long-form generation (scenarios, consolidation). Qwen 3.x may need 8192+.
OPENAI_MAX_TOKENS=8192
OPENAI_TIMEOUT_MS=180000
OPENING_TIMEOUT_MS=180000
# Qwen 3.x: auto skips thinking on simple chat turns via /no_think (on|off|auto)
OPENAI_REASONING_MODE=auto
# Ollama API think:false — broken on some Qwen builds; prefer OPENAI_REASONING_MODE instead
# OPENAI_DISABLE_REASONING=true

# Optional: faster model for scenario generation (falls back to OPENAI_MODEL)
# OPENAI_SCENARIO_MODEL=llama3.2:3b
# Long-form scenario JSON output (default 8192)
# SCENARIO_MAX_TOKENS=8192
# Generation timeout — 0 / unset = no limit (recommended for detailed scenarios)
# SCENARIO_GENERATION_TIMEOUT_MS=0

# Memory / RAG — pull embedding model on Ollama: ollama pull nomic-embed-text
OPENAI_EMBEDDING_MODEL=nomic-embed-text
MEMORY_RAG_TOP_K=6
MEMORY_RAG_MAX_CHARS=8000
MEMORY_TRANSCRIPT_WINDOW=24

# Voice providers (Phase 0/1: noop; Phase 2: elevenlabs)
TTS_PROVIDER=noop
STT_PROVIDER=noop

# ElevenLabs API (TTS + STT — not ElevenLabs Agents)
# ELEVENLABS_API_KEY=
# TTS model (speech engine): eleven_flash_v2_5 = fast; used when no delivery tags
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# TTS model when client uses [pause] [sigh] etc. — auto-switches to v3 when tags present (Starter+)
ELEVENLABS_EXPRESSIVE_MODEL_ID=eleven_v3
# Set false to keep flash and strip tags instead (tags won't be performed)
# ELEVENLABS_USE_EXPRESSIVE_MODEL=false
# STT model — scribe_v2 for record-then-transcribe (works on free tier)
ELEVENLABS_STT_MODEL_ID=scribe_v2
# Premade voice IDs for free-tier API — see src/lib/voice/voice-catalog.ts (Rachel, Adam, Bella, etc.)
# Do not use Voice Library IDs here; they require a paid plan for API access.
# ELEVENLABS_VOICE_ID=
# Optional JSON override for scenario voice matching — see src/lib/voice/voice-catalog.ts
# ELEVENLABS_VOICE_CATALOG=
