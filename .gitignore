# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets; .env.example is the template
.env
.env.local
.env.*.local
!.env.example

# internal planning / cost docs — keep local, not in the repo
/docs/services-and-costs.md

# lip-sync (Rhubarb WASM) runtime assets — regenerated from node_modules by
# scripts/copy-lipsync-assets.mjs on postinstall; the 36 MB data file is huge.
/public/lipsync/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
